# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/

# Editor / OS
.DS_Store
.vscode/
.idea/

# Inspect log files (compressed eval logs)
logs/
*.eval

# Secrets — should never be committed
.env

# Private / not-for-public — funder-facing budgets, draft material
.private/

# Living project reference — private working doc (auto-loads locally, not for the public repo)
CLAUDE.md

# Documentation map — private working index (companion to CLAUDE.md; strip-before-publish)
/DOCS.md

# Decomposition writeup (preprint draft) — stashed until it's a full draft
/FINDINGS.md

# Report build artifacts — regenerate with docs/reports/render.sh
docs/reports/*.typ
docs/reports/*.html
!docs/reports/report-style.html
